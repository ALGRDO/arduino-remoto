[Unit]
Description=Arduino Remote IDE Node.js Server
Documentation=https://github.com/
After=network.target

[Service]
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=BASIC_AUTH_USER=admin
Environment=BASIC_AUTH_PASS=arduino123

Type=simple
# Ensure you update the username and paths appropriately!
User=tu_usuario
WorkingDirectory=/ruta/absoluta/a/prog-remota/server
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
